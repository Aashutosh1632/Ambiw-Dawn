<link rel="stylesheet" href="{{ 'featured-cards-carousel.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'featured-cards-carousel.css' | asset_url }}"></noscript>

<link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}"></noscript>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
<script src="{{ 'featured-cards-carousel.js' | asset_url }}" defer></script>


{%- style -%}
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      order: {{ section.settings.order_no }};
    }
  }
  /* Reserve slide height to prevent CLS before Swiper initializes */
  .featured-carousel .swiper-slide { aspect-ratio: 16 / 9; }
  .featured-carousel .featured-card,
  .featured-carousel .featured-card-inner { height: 100%; }

  /* Reserve slide WIDTH pre-Swiper-init to prevent the flash of full-width image
     during the ~1s window before Swiper hydrates. Width is calc'd to match
     Swiper's final size at slidesPerView:2.5 desktop / 1 mobile, spaceBetween:20/15. */
  .featured-carousel:not(.swiper-initialized) .swiper-slide:first-child {
    width: calc((100% - 40px) / 2.5);
    max-width: calc((100% - 40px) / 2.5);
    box-sizing: border-box;
  }
  @media (max-width: 768px) {
    .featured-carousel:not(.swiper-initialized) .swiper-slide:first-child {
      width: 100%;
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="featured-carousel-wrapper {{ section.settings.custom_class }}">
  <div class="swiper featured-carousel">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}

        {%- assign desktop_image = block.settings.image -%}
        {%- if block.settings.mobile_image != blank -%}
          {%- assign mobile_image = block.settings.mobile_image -%}
        {%- else -%}
          {%- assign mobile_image = desktop_image -%}
        {%- endif -%}

        {%- assign desktop_alt = desktop_image.alt | default: shop.name | escape -%}
        {%- assign mobile_alt = mobile_image.alt | default: shop.name | escape -%}

        <div class="swiper-slide featured-card{% if block.settings.mobile_image == blank %} no-mobile-image{% endif %}" data-real-index="{{ forloop.index0 }}">
          <div class="featured-card-inner">
            <a href="{{ block.settings.link }}">

              {%- if forloop.first -%}
                {%- comment -%} First slide: single <picture> so the browser fetches only the matching image (saves ~one image download on every visit) {%- endcomment -%}
                {%- if desktop_image != blank -%}
                  <picture>
                    {%- if block.settings.mobile_image != blank -%}
                      <source media="(max-width: 768px)"
                              srcset="{{ mobile_image | image_url: width: 375 }} 375w, {{ mobile_image | image_url: width: 550 }} 550w"
                              sizes="100vw"
                              width="{{ mobile_image.width }}"
                              height="{{ mobile_image.height }}">
                    {%- endif -%}
                    <img
                      src="{{ desktop_image | image_url: width: 1200 }}"
                      srcset="{{ desktop_image | image_url: width: 750 }} 750w, {{ desktop_image | image_url: width: 1200 }} 1200w"
                      sizes="100vw"
                      class="featured-img"
                      loading="eager"
                      fetchpriority="high"
                      decoding="async"
                      width="{{ desktop_image.width }}"
                      height="{{ desktop_image.height }}"
                      alt="{{ desktop_alt }}"
                    >
                  </picture>
                {%- endif -%}
              {%- else -%}

                {%- comment -%} Desktop image (subsequent slides) {%- endcomment -%}
                {%- if desktop_image != blank -%}
                  {{ desktop_image | image_url: width: 1200 | image_tag:
                    widths: '550, 750, 1100, 1200',
                    sizes: '(min-width: 750px) 100vw, 0px',
                    class: 'featured-img featured-img-desktop',
                    loading: 'lazy',
                    decoding: 'async',
                    width: desktop_image.width,
                    height: desktop_image.height,
                    alt: desktop_alt
                  }}
                {%- endif -%}

                {%- comment -%} Mobile image (subsequent slides) {%- endcomment -%}
                {%- if mobile_image != blank -%}
                  {{ mobile_image | image_url: width: 550 | image_tag:
                    widths: '375, 550',
                    sizes: '100vw',
                    class: 'featured-img featured-img-mobile',
                    loading: 'lazy',
                    decoding: 'async',
                    width: mobile_image.width,
                    height: mobile_image.height,
                    alt: mobile_alt
                  }}
                {%- endif -%}

              {%- endif -%}

            </a>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <span class="swiper-button-prev"></span>
    <span class="swiper-button-next"></span>
  </div>
  <div class="swiper-pagination"></div>
</div>

{% schema %}
{
  "name": "Featured Cards Carousel",
  "tag": "section",
  "class": "featured-cards-carousel",
  "settings": [
    { "type": "text", "id": "custom_class", "label": "Custom class" },
    { "type": "text", "id": "order_no", "label": "Add Order number" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image (optional)" },
        { "type": "url", "id": "link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Cards Carousel" }]
}
{% endschema %}