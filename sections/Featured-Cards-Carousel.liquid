{%- liquid
  assign cols_d = section.settings.slides_per_view_desktop | default: 2.5
  assign gap_px = section.settings.gap | default: 20
  assign autoplay = section.settings.enable_autoplay
  assign autoplay_delay = section.settings.autoplay_delay | default: 5000
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --fcc-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --fcc-radius: {{ section.settings.border_radius | default: 12 }}px;
    --fcc-cols-d: {{ cols_d }};
    --fcc-gap: {{ gap_px }}px;
    --fcc-accent: {{ section.settings.dot_active_color | default: '#f04f30' }};
    --fcc-pad: {{ section.settings.padding | default: 20 }}px;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      order: {{ section.settings.order_no }};
    }
  }

  .fcc,
  .fcc *,
  .fcc *::before,
  .fcc *::after { box-sizing: border-box; }

  .fcc {
    background: var(--fcc-bg);
    padding: var(--fcc-pad);
    position: relative;
  }
  .fcc__viewport {
    position: relative;
    overflow: hidden;
  }
  .fcc__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--fcc-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .fcc__track::-webkit-scrollbar { display: none; }
  .fcc__slide {
    flex: 0 0 calc((100% - (var(--fcc-cols-d) - 1) * var(--fcc-gap)) / var(--fcc-cols-d));
    scroll-snap-align: start;
    border-radius: var(--fcc-radius);
    overflow: hidden;
    margin: 0;
  }
  @media (max-width: 768px) {
    .fcc__slide { flex: 0 0 100%; }
  }
  .fcc__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .fcc__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--fcc-radius);
  }

  /* Nav arrows */
  .fcc__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fff;
    border: 0;
    color: var(--fcc-accent);
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: opacity .15s, transform .15s;
    padding: 0;
  }
  .fcc__nav:hover { transform: translateY(-50%) scale(1.06); }
  .fcc__nav:disabled { opacity: 0.35; cursor: default; transform: translateY(-50%); }
  .fcc__nav svg { width: 16px; height: 16px; }
  .fcc__nav--prev { left: 6px; }
  .fcc__nav--next { right: 6px; }
  @media (max-width: 768px) {
    .fcc__nav { display: none; }
  }

  /* Dots pagination (mobile only — matches original) */
  .fcc__dots {
    display: none;
    justify-content: center;
    gap: 8px;
    padding-top: 12px;
    list-style: none;
    margin: 0;
  }
  .fcc__dots li { margin: 0; }
  .fcc__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: background .15s;
  }
  .fcc__dot[aria-current="true"] { background: var(--fcc-accent); }
  @media (max-width: 768px) {
    .fcc__dots { display: flex; }
    .fcc { padding: 0; }
  }
{%- endstyle -%}

<section class="fcc{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
         data-fcc
         {% if autoplay %}data-fcc-autoplay="{{ autoplay_delay }}"{% endif %}>
  <div class="fcc__viewport">
    <button type="button" class="fcc__nav fcc__nav--prev" aria-label="Previous slide" data-fcc-prev disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>

    <ul class="fcc__track" data-fcc-track role="list">
      {%- for block in section.blocks -%}
        {%- assign desktop_image = block.settings.image -%}
        {%- assign mobile_image = block.settings.mobile_image | default: desktop_image -%}
        {%- assign desktop_alt = desktop_image.alt | default: shop.name | escape -%}
        {%- assign is_first = forloop.first -%}
        {%- assign img_loading = 'lazy' -%}
        {%- assign img_priority = 'low' -%}
        {%- if is_first -%}
          {%- assign img_loading = 'eager' -%}
          {%- assign img_priority = 'high' -%}
        {%- endif -%}

        <li class="fcc__slide" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a class="fcc__link" href="{{ block.settings.link }}">
          {%- else -%}
            <div class="fcc__link">
          {%- endif -%}

            {%- if desktop_image != blank -%}
              <picture>
                {%- if mobile_image != blank and mobile_image != desktop_image -%}
                  <source media="(max-width: 768px)"
                          srcset="{{ mobile_image | image_url: width: 375 }} 375w, {{ mobile_image | image_url: width: 550 }} 550w, {{ mobile_image | image_url: width: 800 }} 800w"
                          sizes="100vw"
                          width="{{ mobile_image.width }}"
                          height="{{ mobile_image.height }}">
                {%- endif -%}
                <img class="fcc__img"
                     src="{{ desktop_image | image_url: width: 1200 }}"
                     srcset="{{ desktop_image | image_url: width: 600 }} 600w, {{ desktop_image | image_url: width: 800 }} 800w, {{ desktop_image | image_url: width: 1200 }} 1200w, {{ desktop_image | image_url: width: 1600 }} 1600w"
                     sizes="(min-width: 769px) calc(100vw / {{ cols_d }}), 100vw"
                     width="{{ desktop_image.width }}"
                     height="{{ desktop_image.height }}"
                     alt="{{ desktop_alt }}"
                     loading="{{ img_loading }}"
                     fetchpriority="{{ img_priority }}"
                     decoding="async">
              </picture>
            {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <button type="button" class="fcc__nav fcc__nav--next" aria-label="Next slide" data-fcc-next>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>

  <ul class="fcc__dots" data-fcc-dots role="list">
    {%- for block in section.blocks -%}
      <li>
        <button type="button"
                class="fcc__dot"
                data-fcc-dot="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}"
                {% if forloop.first %}aria-current="true"{% endif %}></button>
      </li>
    {%- endfor -%}
  </ul>
</section>

<script>
  (function () {
    var root = document.currentScript && document.currentScript.previousElementSibling;
    // Resolve to nearest [data-fcc] ancestor (handles whitespace nodes)
    while (root && !(root.nodeType === 1 && root.matches && root.matches('[data-fcc]'))) {
      root = root.previousElementSibling;
    }
    if (!root || root.dataset.fccBound) return;
    root.dataset.fccBound = '1';

    var track = root.querySelector('[data-fcc-track]');
    var prev = root.querySelector('[data-fcc-prev]');
    var next = root.querySelector('[data-fcc-next]');
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-fcc-dot]'));
    if (!track) return;

    function slideStep() {
      var first = track.children[0];
      if (!first) return 0;
      var style = getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap) || 0;
      return first.getBoundingClientRect().width + gap;
    }

    function updateState() {
      var step = slideStep();
      if (!step) return;
      var idx = Math.round(track.scrollLeft / step);
      idx = Math.max(0, Math.min(idx, track.children.length - 1));
      if (prev) prev.disabled = track.scrollLeft <= 1;
      if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
      dots.forEach(function (d, i) {
        if (i === idx) d.setAttribute('aria-current', 'true');
        else d.removeAttribute('aria-current');
      });
    }

    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -slideStep(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function () { track.scrollBy({ left:  slideStep(), behavior: 'smooth' }); });
    dots.forEach(function (d, i) {
      d.addEventListener('click', function () { track.scrollTo({ left: i * slideStep(), behavior: 'smooth' }); });
    });

    var raf;
    track.addEventListener('scroll', function () {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(updateState);
    });
    window.addEventListener('resize', updateState);

    // Optional autoplay
    var delay = parseInt(root.dataset.fccAutoplay, 10);
    if (delay > 0) {
      var timer = null;
      var paused = false;
      function tick() {
        if (paused) return;
        var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
        if (atEnd) track.scrollTo({ left: 0, behavior: 'smooth' });
        else track.scrollBy({ left: slideStep(), behavior: 'smooth' });
      }
      function start() { stop(); timer = setInterval(tick, delay); }
      function stop()  { if (timer) { clearInterval(timer); timer = null; } }
      root.addEventListener('mouseenter', function () { paused = true; });
      root.addEventListener('mouseleave', function () { paused = false; });
      track.addEventListener('pointerdown', function () { paused = true; });
      // Pause when off-screen
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) start(); else stop(); });
        }, { threshold: 0.1 }).observe(root);
      } else {
        start();
      }
    }

    updateState();
  })();
</script>

{% schema %}
{
  "name": "Featured Cards Carousel",
  "tag": "section",
  "class": "featured-cards-carousel",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "min": 1,
      "max": 4,
      "step": 0.5,
      "default": 2.5,
      "label": "Slides per view (desktop)"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Gap between slides"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12,
      "unit": "px",
      "label": "Slide border radius"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Section padding (desktop)"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Section background"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "default": "#f04f30",
      "label": "Active dot / arrow color"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "Enable autoplay",
      "info": "Off by default for best performance. Pauses on hover, on user interaction, and when off-screen."
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 2000,
      "max": 10000,
      "step": 500,
      "default": 5000,
      "unit": "ms",
      "label": "Autoplay delay"
    },
    {
      "type": "header",
      "content": "Misc"
    },
    { "type": "text", "id": "custom_class", "label": "Custom class" },
    { "type": "text", "id": "order_no", "label": "Mobile order number" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (desktop)" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image (optional)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Cards Carousel" }]
}
{% endschema %}
