{%- if section.settings.enable_seo_schema -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      {% if settings.logo %}
        "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
      {% endif %}
      "sameAs": [
        {{ settings.social_twitter_link | json }},
        {{ settings.social_facebook_link | json }},
        {{ settings.social_pinterest_link | json }},
        {{ settings.social_instagram_link | json }},
        {{ settings.social_tiktok_link | json }},
        {{ settings.social_tumblr_link | json }},
        {{ settings.social_snapchat_link | json }},
        {{ settings.social_youtube_link | json }},
        {{ settings.social_vimeo_link | json }}
      ],
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>

  {%- if request.page_type == 'index' -%}
    {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ potential_action_target | json }},
          "query-input": "required name=search_term_string"
        },
        "url": {{ request.origin | append: page.url | json }}
      }
    </script>
  {%- endif -%}
{%- endif -%}

{%- liquid
  assign logo_image = section.settings.logo
  assign show_search = section.settings.show_search
  assign show_wishlist = section.settings.show_wishlist
  assign show_cart = section.settings.show_cart
  assign show_account = section.settings.show_account
  assign mobile_menu = linklists[section.settings.mobile_menu]
  assign show_hamburger = section.settings.show_hamburger
  assign gp_image = section.settings.mobile_gp_image
  assign as_image = section.settings.mobile_as_image
  assign show_mobile_app_badges = false
  if section.settings.show_mobile_app_badges
    if gp_image != blank or as_image != blank
      assign show_mobile_app_badges = true
    endif
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --ch-bg: {{ section.settings.background_color | default: '#0d1627' }};
    --ch-fg: {{ section.settings.text_color | default: '#ffffff' }};
    --ch-accent: {{ section.settings.accent_color | default: '#ef3639' }};
    --ch-search-bg: {{ section.settings.search_bg_color | default: '#ffffff' }};
    --ch-search-fg: {{ section.settings.search_text_color | default: '#161616' }};
    --ch-pad-y: {{ section.settings.padding_vertical }}px;
    --ch-logo-w: {{ section.settings.logo_width }}px;
  }
  .ds-header,
  .ds-header *,
  .ds-header *::before,
  .ds-header *::after {
    box-sizing: border-box;
  }
  .ds-header {
    background: var(--ch-bg);
    color: var(--ch-fg);
    padding-block: var(--ch-pad-y);
  }
  .ds-header__inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .ds-header__logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    font-weight: 700;
    font-size: 20px;
  }
  .ds-header__logo img {
    display: block;
    width: var(--ch-logo-w);
    height: auto;
    max-height: 60px;
    object-fit: contain;
  }
  .ds-header__search {
    flex: 1 1 auto;
    display: flex;
    align-items: stretch;
    background: var(--ch-search-bg);
    color: var(--ch-search-fg);
    border-radius: 4px;
    overflow: hidden;
    min-width: 0;
    min-height: 40px;
  }
  .ds-header__search-input {
    flex: 1 1 auto;
    border: 0;
    outline: 0;
    margin: 0;
    padding: 10px 16px;
    background: transparent;
    color: var(--ch-search-fg);
    font: inherit;
    min-width: 0;
    -webkit-appearance: none;
    appearance: none;
    height: auto;
    box-shadow: none;
  }
  .ds-header__search-input::-webkit-search-decoration,
  .ds-header__search-input::-webkit-search-cancel-button,
  .ds-header__search-input::-webkit-search-results-button,
  .ds-header__search-input::-webkit-search-results-decoration { display: none; }
  .ds-header__search-input::placeholder { color: rgba(0,0,0,0.45); opacity: 1; }
  .ds-header__search-btn {
    flex: 0 0 auto;
    background: var(--ch-accent);
    color: #fff;
    border: 0;
    margin: 0;
    padding: 0 18px;
    min-width: 56px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    line-height: 1;
    -webkit-appearance: none;
    appearance: none;
    align-self: stretch;
  }
  .ds-header__search-btn:hover { filter: brightness(1.08); }
  .ds-header__search-btn svg { width: 18px; height: 18px; }
  .ds-header__icons {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .ds-header__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: inherit;
    font-size: 12px;
    line-height: 1.1;
  }
  .ds-header__icon:hover { color: var(--ch-accent); }
  .ds-header__icon svg {
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
  }
  .ds-header__icon-label {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .ds-header__chevron { width: 10px; height: 10px; flex: 0 0 10px; }
  .ds-header__badge {
    position: absolute;
    top: -6px;
    right: -10px;
    background: var(--ch-accent);
    color: #fff;
    border-radius: 999px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    font-size: 11px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    box-sizing: border-box;
  }

  @media (max-width: 989px) {
    .ds-header__icon-label,
    .ds-header__chevron { display: none; }
  }
  @media (max-width: 749px) {
    .ds-header__inner { flex-wrap: wrap; gap: 10px; }
    .ds-header__hamburger { order: 0; }
    .ds-header__logo { flex: 1 1 auto; order: 1; justify-content: center; text-align: center; }
    .ds-header__logo img { margin-inline: auto; }
    .ds-header__icons { gap: 14px; order: 2; }
    .ds-header__search { order: 3; flex-basis: 100%; }
    .ds-header__app-badges { order: 4; flex-basis: 100%; }
    .ds-header__search-input { padding: 8px 12px; }
    .ds-header__search-btn { padding: 0 14px; }
  }

  /* Hamburger button (mobile only by default) */
  .ds-header__hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: inherit;
    width: 40px;
    height: 40px;
    margin: 0;
    padding: 0;
    cursor: pointer;
    border-radius: 4px;
    flex: 0 0 40px;
  }
  .ds-header__hamburger:hover { background: rgba(255,255,255,0.08); }
  .ds-header__hamburger svg { width: 24px; height: 24px; }
  @media (max-width: 989px) {
    .ds-header__hamburger { display: inline-flex; }
  }

  /* Mobile app badges row */
  .ds-header__app-badges {
    display: none;
    gap: 10px;
    justify-content: center;
    align-items: center;
  }
  @media (max-width: 749px) {
    .ds-header__app-badges { display: flex; }
  }
  .ds-header__app-badges a { display: inline-flex; }
  .ds-header__app-badges img {
    height: {{ section.settings.mobile_app_badge_height | default: 36 }}px;
    width: auto;
    display: block;
  }

  /* Mobile drawer */
  .ds-mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
  }
  .ds-mobile-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity .28s ease;
    pointer-events: none;
  }
  .ds-mobile-drawer__panel {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(85vw, 360px);
    background: #fff;
    color: #161616;
    transform: translateX(-100%);
    transition: transform .28s ease;
    overflow-y: auto;
    pointer-events: auto;
    display: flex;
    flex-direction: column;
  }
  .ds-mobile-drawer.is-open { pointer-events: auto; }
  .ds-mobile-drawer.is-open .ds-mobile-drawer__overlay { opacity: 1; pointer-events: auto; }
  .ds-mobile-drawer.is-open .ds-mobile-drawer__panel { transform: translateX(0); }

  .ds-mobile-drawer__close {
    position: sticky;
    top: 0;
    background: #fff;
    border: 0;
    width: 100%;
    text-align: right;
    padding: 14px 16px;
    cursor: pointer;
    color: inherit;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    z-index: 1;
  }
  .ds-mobile-drawer__close svg { width: 24px; height: 24px; }
  .ds-mobile-drawer__list,
  .ds-mobile-drawer__sublist,
  .ds-mobile-drawer__subsublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ds-mobile-drawer__item { border-bottom: 1px solid rgba(0,0,0,0.06); }
  .ds-mobile-drawer details > summary,
  .ds-mobile-drawer__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }
  .ds-mobile-drawer details > summary::-webkit-details-marker { display: none; }
  .ds-mobile-drawer details > summary::marker { content: ''; }
  .ds-mobile-drawer__chev {
    width: 14px;
    height: 14px;
    transition: transform .18s;
  }
  .ds-mobile-drawer details[open] > summary > .ds-mobile-drawer__chev { transform: rotate(180deg); }
  .ds-mobile-drawer__sublist {
    background: rgba(0,0,0,0.03);
    padding-left: 12px;
  }
  .ds-mobile-drawer__sublist > li { border-top: 1px solid rgba(0,0,0,0.05); }
  .ds-mobile-drawer__sublink,
  .ds-mobile-drawer__sublist a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    color: inherit;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
  }
  .ds-mobile-drawer__subsublist {
    background: rgba(0,0,0,0.05);
    padding-left: 12px;
  }
  .ds-mobile-drawer__subsublist > li { border-top: 1px solid rgba(0,0,0,0.05); }
  .ds-mobile-drawer__subsublist a {
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 400;
    display: block;
    color: inherit;
    text-decoration: none;
  }
{%- endstyle -%}

<div class="ds-header">
  <div class="ds-header__inner page-width">

    {%- if show_hamburger -%}
      <button type="button"
              class="ds-header__hamburger"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="ds-header-drawer-{{ section.id }}"
              data-drawer-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
      </button>
    {%- endif -%}

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="ds-header__logo" aria-label="{{ shop.name | escape }}">
      {%- if logo_image != blank -%}
        <img src="{{ logo_image | image_url: width: 320 }}"
             srcset="{{ logo_image | image_url: width: 160 }} 160w, {{ logo_image | image_url: width: 240 }} 240w, {{ logo_image | image_url: width: 320 }} 320w, {{ logo_image | image_url: width: 480 }} 480w"
             sizes="{{ section.settings.logo_width }}px"
             width="{{ logo_image.width }}"
             height="{{ logo_image.height }}"
             alt="{{ shop.name | escape }}"
             loading="eager"
             fetchpriority="high"
             decoding="async">
      {%- else -%}
        <span>{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Search {%- endcomment -%}
    {%- if show_search -%}
      <form action="{{ routes.search_url }}" method="get" role="search" class="ds-header__search">
        <input type="hidden" name="type" value="{{ section.settings.search_type }}">
        <input type="hidden" name="options[prefix]" value="last">
        <input type="search"
               name="q"
               class="ds-header__search-input"
               placeholder="{{ section.settings.search_placeholder | default: 'Search' }}"
               aria-label="Search"
               autocomplete="off"
               spellcheck="false">
        <button type="submit" class="ds-header__search-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
      </form>
    {%- endif -%}

    {%- comment -%} Right-side icons {%- endcomment -%}
    <div class="ds-header__icons">

      {%- if show_account -%}
        {%- if customer -%}
          {%- assign account_url = routes.account_url -%}
          {%- assign account_aria = 'Account' -%}
        {%- else -%}
          {%- assign account_url = routes.account_login_url -%}
          {%- assign account_aria = 'Sign in' -%}
        {%- endif -%}
        <a href="{{ account_url }}" class="ds-header__icon" aria-label="{{ account_aria }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 21a8 8 0 0 1 16 0"/>
          </svg>
          {%- if section.settings.show_account_label -%}
            <span class="ds-header__icon-label">{{ section.settings.account_label }}</span>
            <svg class="ds-header__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          {%- endif -%}
        </a>
      {%- endif -%}

      {%- if show_wishlist -%}
        <a href="{{ section.settings.wishlist_link | default: '#' }}" class="ds-header__icon" aria-label="Wishlist">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          {%- if section.settings.wishlist_count != blank and section.settings.wishlist_count != '0' -%}
            <span class="ds-header__badge">{{ section.settings.wishlist_count }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}

      {%- if show_cart -%}
        {%- assign cart_action = section.settings.cart_action | default: 'drawer' -%}
        <a href="{{ routes.cart_url }}"
           class="ds-header__icon"
           {% if cart_action == 'drawer' %}id="cart-icon-bubble" aria-controls="CartDrawer"{% endif %}
           aria-label="Cart, {{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="20" r="1.5"/>
            <circle cx="18" cy="20" r="1.5"/>
            <path d="M3 4h2l2.7 12.4a2 2 0 0 0 2 1.6h7.6a2 2 0 0 0 2-1.55L21 8H6"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="ds-header__badge" data-cart-count>{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}

    </div>

    {%- if show_mobile_app_badges -%}
      <div class="ds-header__app-badges">
        {%- if gp_image != blank -%}
          <a href="{{ section.settings.mobile_gp_link | default: '#' }}"
             {% if section.settings.mobile_app_links_new_tab %}target="_blank" rel="noopener"{% endif %}
             aria-label="Get it on Google Play">
            <img src="{{ gp_image | image_url: width: 280 }}"
                 width="{{ gp_image.width }}"
                 height="{{ gp_image.height }}"
                 alt="Get it on Google Play"
                 loading="lazy"
                 decoding="async">
          </a>
        {%- endif -%}
        {%- if as_image != blank -%}
          <a href="{{ section.settings.mobile_as_link | default: '#' }}"
             {% if section.settings.mobile_app_links_new_tab %}target="_blank" rel="noopener"{% endif %}
             aria-label="Download on the App Store">
            <img src="{{ as_image | image_url: width: 280 }}"
                 width="{{ as_image.width }}"
                 height="{{ as_image.height }}"
                 alt="Download on the App Store"
                 loading="lazy"
                 decoding="async">
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- if show_hamburger and mobile_menu != blank and mobile_menu.links.size > 0 -%}
  <div class="ds-mobile-drawer"
       id="ds-header-drawer-{{ section.id }}"
       data-drawer
       hidden>
    <div class="ds-mobile-drawer__overlay" data-drawer-close></div>
    <div class="ds-mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
      <button type="button" class="ds-mobile-drawer__close" aria-label="Close menu" data-drawer-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="m6 6 12 12M6 18 18 6"/>
        </svg>
      </button>
      <ul class="ds-mobile-drawer__list">
        {%- for link in mobile_menu.links -%}
          <li class="ds-mobile-drawer__item">
            {%- if link.links.size > 0 -%}
              <details>
                <summary>
                  <span>{{ link.title | escape }}</span>
                  <svg class="ds-mobile-drawer__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </summary>
                <ul class="ds-mobile-drawer__sublist">
                  {%- for sub in link.links -%}
                    <li>
                      {%- if sub.links.size > 0 -%}
                        <details>
                          <summary class="ds-mobile-drawer__sublink">
                            <span>{{ sub.title | escape }}</span>
                            <svg class="ds-mobile-drawer__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path d="m6 9 6 6 6-6"/>
                            </svg>
                          </summary>
                          <ul class="ds-mobile-drawer__subsublist">
                            {%- for grand in sub.links -%}
                              <li><a href="{{ grand.url }}">{{ grand.title | escape }}</a></li>
                            {%- endfor -%}
                          </ul>
                        </details>
                      {%- else -%}
                        <a href="{{ sub.url }}" class="ds-mobile-drawer__sublink">{{ sub.title | escape }}</a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            {%- else -%}
              <a href="{{ link.url }}" class="ds-mobile-drawer__link">{{ link.title | escape }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <script>
    (function () {
      var section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section || section.dataset.drawerBound) return;
      section.dataset.drawerBound = '1';

      var drawer = section.querySelector('[data-drawer]');
      var opener = section.querySelector('[data-drawer-open]');
      var closers = section.querySelectorAll('[data-drawer-close]');
      if (!drawer || !opener) return;

      function openDrawer() {
        opener.setAttribute('aria-expanded', 'true');
        drawer.removeAttribute('hidden');
        // Force layout, then add class to trigger transition
        void drawer.offsetWidth;
        drawer.classList.add('is-open');
        document.documentElement.style.overflow = 'hidden';
      }
      function closeDrawer() {
        if (!drawer.classList.contains('is-open')) return;
        opener.setAttribute('aria-expanded', 'false');
        drawer.classList.remove('is-open');
        document.documentElement.style.overflow = '';
        setTimeout(function () {
          if (!drawer.classList.contains('is-open')) drawer.setAttribute('hidden', '');
        }, 300);
      }

      opener.addEventListener('click', openDrawer);
      closers.forEach(function (el) { el.addEventListener('click', closeDrawer); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDrawer();
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Custom header",
  "tag": "section",
  "class": "section section-custom-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "SEO"
    },
    {
      "type": "checkbox",
      "id": "enable_seo_schema",
      "default": true,
      "label": "Add Organization & WebSite JSON-LD",
      "info": "Outputs schema.org structured data for SEO. Disable if your theme already does this elsewhere."
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "If empty, the shop name is shown as text."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 240,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "default": true,
      "label": "Show search bar"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "default": "Search for products",
      "label": "Search placeholder"
    },
    {
      "type": "select",
      "id": "search_type",
      "label": "Search scope",
      "default": "product",
      "options": [
        { "value": "product", "label": "Products only" },
        { "value": "product,article,page", "label": "Products + articles + pages" }
      ]
    },
    {
      "type": "header",
